{
  "name": "@signalk/aisreporter",
  "version": "1.1.0",
  "description": "Signal K server plugin to report your position to MarineTraffic, AISHub, and other similar aggregators",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "keywords": [
    "signalk-node-server-plugin"
  ],
  "author": "Teppo Kurki <teppo.kurki@iki.fi>",
  "contributors": [
    {
      "name": "Scott Bender"
    }
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/SignalK/aisreporter"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rimraf dist",
    "prebuild": "npm run clean",
    "typecheck": "tsc --noEmit",
    "test": "mocha",
    "coverage": "c8 --reporter=text --reporter=lcov npm test",
    "mutation": "stryker run",
    "prettier:check": "prettier --check .",
    "prettier": "prettier --write .",
    "format": "npm run prettier",
    "prepublishOnly": "npm run build"
  },
  "c8": {
    "extension": [
      ".ts"
    ],
    "include": [
      "src/**/*.ts"
    ],
    "exclude": [
      "src/**/*.d.ts",
      "test/**",
      "coverage/**",
      "dist/**"
    ],
    "all": true,
    "reporter": [
      "text",
      "lcov"
    ]
  },
  "dependencies": {
    "ggencoder": "^1.0.9"
  },
  "peerDependencies": {
    "baconjs": "^3.0.0"
  },
  "devDependencies": {
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/mocha-runner": "^9.6.1",
    "@types/chai": "^4.3.20",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.10.5",
    "baconjs": "^3.0.0",
    "c8": "^11.0.0",
    "chai": "^4.5.0",
    "mocha": "^11.7.5",
    "prettier": "^3.8.2",
    "rimraf": "^6.1.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
